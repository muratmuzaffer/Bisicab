# Expo herkese açık env değişkenleri (EXPO_PUBLIC_ önekiyle istemciye gömülür)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Sadece NATIVE DERLEME için gizli token (sk...). Public DEĞİLDİR, commit etmeyin.
# app.config.ts bunu @rnmapbox/maps download token olarak kullanır.
MAPBOX_DOWNLOAD_TOKEN=sk.your-mapbox-secret-download-token
