{
  "name": "bisicab",
  "version": "0.1.0",
  "private": true,
  "description": "BisiCab - Elektrikli bisikletli yolcu taşıma platformu (İZULAŞ / Alsancak Limanı - Konak Saat Kulesi)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace @bisicab/mobile",
    "admin": "npm run dev --workspace @bisicab/admin",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "build:shared": "npm run build --workspace @bisicab/shared"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
